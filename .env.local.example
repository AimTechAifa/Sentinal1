OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Clerk (required for sign-in) — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
# In Clerk Dashboard → Configure → Domains, add your Vercel URL (e.g. sentinal1-phi.vercel.app)

# Postgres (Neon) — required for seeded workbook data
DATABASE_URL=

# Upstash Redis (optional) — caches dashboard/inbox for ~60s to reduce Neon load.
# Free tier: ~500k commands/month. Only dashboard + inbox use Redis (not live-state polling).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Connector Engine — AES-256 key for encrypting stored connector credentials (32 bytes, base64).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CONNECTOR_ENCRYPTION_KEY=

# Connector Engine service (Railway/Render locally: http://localhost:3100)
CONNECTOR_ENGINE_URL=http://localhost:3100
CONNECTOR_ENGINE_API_KEY=
